{
  "permissions": {
    "allow": [
      "Bash(lsof -ti:*)",
      "Bash(kill *)",
      "Bash(sleep *)",
      "Bash(curl *)",
      "Bash(rm -rf */backend/data/xtdb)",
      "Bash(cd */backend && export $(cat .env | xargs) && clj *)",
      "Bash(export $(cat .env | xargs) && clj *)",
      "Bash(cd */frontend && export $(cat .env | xargs) && npm *)",
      "Bash(export $(cat .env | xargs) && npm *)",
      "Bash(npx shadow-cljs *)",
      "Bash(clj -M:test*)",
      "Bash(lsof -ti:3000*)",
      "Bash(lsof -ti:3449*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  }
}
