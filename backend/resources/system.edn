{:log/mulog
 {:type   :multi
  :publishers [{:type :console}
               {:type     :simple-file
                :filename "log/app.log"}]}

 :xtdb/node
 {:dir "data/xtdb"}

 :users/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :networks/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :networks/seed
 {:repo #ig/ref :networks/xtdb-repo}

 :consumptions/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :productions/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :eligibility-checks/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :alerts/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :news/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :auth/token-verifier
 {:client-ids {:google   #env GOOGLE_CLIENT_ID
               :apple    #env APPLE_CLIENT_ID
               :facebook #env FACEBOOK_APP_ID}}

 :auth/jwt-secret
 {:secret #env JWT_SECRET}

 :auth/password-hasher {}

 :verification-tokens/xtdb-repo
 {:node #ig/ref :xtdb/node}

 :email/resend-sender
 {:api-key        #env RESEND_API_KEY
  :from-email     #profile {:dev     "onboarding@resend.dev"
                             :staging #env EMAIL_FROM
                             :prod    #env EMAIL_FROM}
  :noreply-email  #profile {:dev     "onboarding@resend.dev"
                             :staging #env EMAIL_NOREPLY
                             :prod    #env EMAIL_NOREPLY}
  :app-base-url   #profile {:dev "http://localhost:3449"
                             :staging #env APP_BASE_URL
                             :prod    #env APP_BASE_URL}}

 :docuseal/gateway
 {:api-key  #env DOCUSEAL_API_KEY
  :api-base "https://api.docuseal.com"}

 :http/handler
 {:cors-origins   #profile {:dev     ["http://localhost:3449"]
                             :staging [#env CORS_ORIGIN]
                             :prod    [#env CORS_ORIGIN]}
  :network-repo          #ig/ref :networks/xtdb-repo
  :user-repo             #ig/ref :users/xtdb-repo
  :consumption-repo      #ig/ref :consumptions/xtdb-repo
  :production-repo       #ig/ref :productions/xtdb-repo
  :eligibility-check-repo #ig/ref :eligibility-checks/xtdb-repo
  :token-verifier        #ig/ref :auth/token-verifier
  :password-hasher       #ig/ref :auth/password-hasher
  :email-sender          #ig/ref :email/resend-sender
  :verification-token-repo #ig/ref :verification-tokens/xtdb-repo
  :jwt-secret            #ig/ref :auth/jwt-secret
  :alert-banner-repo     #ig/ref :alerts/xtdb-repo
  :news-repo             #ig/ref :news/xtdb-repo
  :document-signer       #ig/ref :docuseal/gateway}

 :http/server
 {:port    #profile {:dev 3000 :staging 8080 :prod 8080}
  :handler #ig/ref :http/handler}}
